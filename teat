local function IsPlayerValid(plr)
    if plr and plr.Character and plr.Character:FindFirstChild('HumanoidRootPart') and plr.Character:FindFirstChild('Humanoid') and plr.Character:FindFirstChild('Head') then
        return true
    end
    return false
end

local function GetScreenPos(Object)
    local pos = Camera:WorldToScreenPoint(Object.Position)
    return pos
end

local function IsVisible(Part, PartDescendant)
    if not getgenv().Looten.Adjustment.Checks.Wall_Check then return true end
    
    local Character = Client.Character or Client.CharacterAdded:Wait()
    local Origin = Camera.CFrame.Position
    local _, OnScreen = Camera:WorldToViewportPoint(Part.Position)

    if OnScreen then
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        raycastParams.FilterDescendantsInstances = { Character, Camera }

        local Result = Workspace:Raycast(Origin, Part.Position - Origin, raycastParams)

        if Result then
            local PartHit = Result.Instance
            local Visible = (not PartHit or PartHit:IsDescendantOf(PartDescendant))
            return Visible
        end
    end
    return false
end

local function GetClosestBodyPart(character)
    local ClosestDistance = math.huge
    local BodyPart = nil
    
    if character then
        for _, x in pairs(character:GetChildren()) do
            if x:IsA("BasePart") and (x.Name == "Head" or x.Name == "HumanoidRootPart" or x.Name == "UpperTorso" or x.Name == "LowerTorso") then
                local Position, OnScreen = Camera:WorldToViewportPoint(x.Position)
                if OnScreen then
                    local Distance = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(Position.X, Position.Y)).Magnitude
                    if Distance < ClosestDistance then
                        ClosestDistance = Distance
                        BodyPart = x
                    end
                end
            end
        end
    end
    return BodyPart
end

local function GetBestTargetLooten()
    local FoundTarget, Closest = nil, math.huge
    local MousePos = UserInputService:GetMouseLocation() -- Besser als Mouse.X/Y für Silent Aim

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= Client and v.Character and v.Character:FindFirstChild('HumanoidRootPart') then
            -- Checks
            local char = v.Character
            if getgenv().Looten.Adjustment.Checks.Knocked_Check then
                local be = char:FindFirstChild("BodyEffects")
                if be and be:FindFirstChild("K.O") and be["K.O"].Value then continue end
                if char:FindFirstChild("GRABBING_CONSTRAINT") then continue end
            end

            if getgenv().Looten.Adjustment.Checks.Crew_Check then
                -- Crew logic here if needed
            end

            local AimPart = char.HumanoidRootPart
            if IsVisible(AimPart, char) then
                local Pos, OnScreen = Camera:WorldToViewportPoint(AimPart.Position)
                if OnScreen then
                    local Distance = (Vector2.new(MousePos.X, MousePos.Y) - Vector2.new(Pos.X, Pos.Y)).Magnitude
                    if Distance < Closest and Distance <= getgenv().Looten.Fov.SilentAim.Radius then
                        Closest = Distance
                        FoundTarget = v
                    end
                end
            end
        end
    end
    return FoundTarget
end

local function CalculatePredictionLooten(TargetPlayer)
    if not IsPlayerValid(TargetPlayer) then return nil, nil end

    local TargetChar = TargetPlayer.Character
    local HitPartName = getgenv().Looten.Silent.HitPart.HitPart
    
    if getgenv().Looten.Silent.HitPart.NearestPoint then
        local nearest = GetClosestBodyPart(TargetChar)
        if nearest then HitPartName = nearest.Name end
    end

    local TargetPart = TargetChar:FindFirstChild(HitPartName)
    if not TargetPart then return nil, nil end

    local TargetCF = TargetPart.CFrame
    local TargetVel = TargetChar.HumanoidRootPart.Velocity
    local TargetMov = TargetChar.Humanoid.MoveDirection
    local SilentPos = TargetCF.Position

    local usePrediction = false
    if getgenv().DD then
        local mag = TargetVel.magnitude
        if mag > getgenv().DV then usePrediction = true
        elseif mag < 1 and TargetMov.magnitude > 0.01 then usePrediction = true
        elseif mag > 5 and TargetMov.magnitude < 0.01 then usePrediction = true
        end
    end

    if getgenv().Looten.Adjustment.Checks.NoGroundShots and TargetVel.Y < getgenv().WAGA then
        SilentPos = TargetCF.Position + (Vector3.new(TargetVel.X, (TargetVel.Y * getgenv().AGV), TargetVel.Z) * getgenv().Looten.Silent.Prediction.Prediction)
    elseif getgenv().DUG and TargetVel.Y < getgenv().UD then
        SilentPos = TargetCF.Position + (Vector3.new(TargetVel.X, 0, TargetVel.Z) * getgenv().Looten.Silent.Prediction.Prediction)
    elseif usePrediction or getgenv().Looten.Silent.Prediction.Enabled then
        -- Standard Prediction
        SilentPos = TargetCF.Position + (TargetVel * getgenv().Looten.Silent.Prediction.Prediction)
    end

    return SilentPos, TargetPart
end


