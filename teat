local function CheckGun()
    local char = LP.Character
    if not char then return false end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return false end
    if tool:FindFirstChild("Handle") and not tool.Name:lower():find("wallet") and not tool.Name:lower():find("phone") then
        return true
    end
    return false
end


table.insert(getgenv().SchmecktHubConnections, RunService.RenderStepped:Connect(function()
    if not Shared.SilentAim then
        UI.Enabled = false
        return
    end
    
    UI.Enabled = true
    local mousePos = UserInputService:GetMouseLocation()
    Circle.Position = UDim2.new(0, mousePos.X, 0, mousePos.Y)
    
    IsGunEquipped = CheckGun()
    
    Target = nil
    Pos = nil
    Part = nil
    TargetMarker.Visible = false
    Stroke.Color = Color3.fromRGB(255, 255, 255)

    if IsGunEquipped then
        local Found = GetBestTargetLooten()
        
        if Found then
            Target = Found
            local pPos, pPart = CalculatePredictionLooten(Target)
            if pPos then
                Pos = pPos
                Part = pPart
                
                local screenPos, onScreen = Camera:WorldToViewportPoint(Pos)
                if onScreen then
                    TargetMarker.Visible = true
                    TargetMarker.Position = UDim2.new(0, screenPos.X, 0, screenPos.Y)
                    Stroke.Color = Color3.fromRGB(255, 50, 50) -- Roter Kreis wenn locked
                end
            end
        end
    end
end))


local mt = getrawmetatable(game)
local oldNc = mt.__namecall
local oldIdx = mt.__index
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local m = getnamecallmethod()
    local args = {...}

    if IsGunEquipped and Target and Pos and Shared.SilentAim then
        if m == "Raycast" and self == Workspace then
            if args[1] and args[2] then
                -- Redirect Raycast to Predicted Position
                return oldNc(self, args[1], (Pos - args[1]).Unit * 1000, unpack(args, 3))
            end
        end
        
        if self == CachedMouse then
            if m == "GetHit" then return CFrame.new(Pos) end
            if m == "GetTarget" then return Part end
        end
    end
    return oldNc(self, ...)
end)

mt.__index = newcclosure(function(self, k)
    if IsGunEquipped and Target and Pos and Shared.SilentAim then
        if self == CachedMouse then
            if k == "Hit" then return CFrame.new(Pos) end
            if k == "Target" then return Part end
            if k == "X" then return Pos.X end
            if k == "Y" then return Pos.Y end
            if k == "Z" then return Pos.Z end
        end
    end
    return oldIdx(self, k)
end)

setreadonly(mt, true)
